<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.cyh.mapper.UserMapper">
    <insert id="insertAvatar">
        UPDATE t_user SET Avatar = #{avatar} WHERE id = #{userId}
    </insert>

    <!-- Find user by username -->
    <select id="findByUsername" parameterType="java.lang.String" resultType="com.cyh.entity.User">
        SELECT * FROM t_user WHERE username = #{username} AND is_deleted = 0
    </select>

    <!-- Find user by email -->
    <select id="findByEmail" parameterType="java.lang.String" resultType="com.cyh.entity.User">
        SELECT * FROM t_user WHERE email = #{email} AND is_deleted = 0
    </select>

    <!-- Find user by phone -->
    <select id="findByPhone" parameterType="java.lang.String" resultType="com.cyh.entity.User">
        SELECT * FROM t_user WHERE phone = #{phone} AND is_deleted = 0
    </select>

</mapper>
