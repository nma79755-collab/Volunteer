<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.messageservice.mapper.MessageMapper">


    <insert id="insertMessage">
        insert into t_message(content,sender,receiver,sendTime,status) values(#{content},#{sender},#{receiver},#{sendTime},#{status})
    </insert>
</mapper>
